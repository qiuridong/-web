# =========================================
# 签到脚本聚合管理面板 · 环境变量示例
# =========================================
# 用法: cp .env.example .env  然后改下面的值
# .env 不入 git,真实部署请妥善保管
# =========================================

# ===== 部署相关 =====
# 容器内运行用户的 UID/GID,应当与 host 上 ./data ./scripts 目录的属主一致
# 推荐:host 上跑 `id -u && id -g`,把得到的两个数字填进来
UID=1000
GID=1000

# 时区(影响 cron 表达式解析与日志时间显示)
TZ=Asia/Shanghai

# ===== 后端 =====
# 业务数据库路径(容器内绝对路径)
DATABASE_URL=sqlite:////app/data/db.sqlite3

# 调度器 jobstore 路径(独立 SQLite 避免锁竞争)
SCHEDULER_DB_URL=sqlite:////app/data/scheduler.db

# Fernet 加密主密钥文件路径
# ⚠️ 首次启动会自动生成。生成后请立即异地离线备份(密码管理器/打印纸)
# ⚠️ 丢失此密钥 = 所有 secret 配置作废
ENCRYPTION_KEY_PATH=/app/data/encryption.key

# 应用日志级别 (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO

# 应用监听端口(容器内)
PORT=8000

# uvicorn worker 数(必须 = 1,APScheduler 同进程模式禁止多 worker)
WORKERS=1

# ===== Caddy / 反代 =====
# 你的域名(用于 Caddy 自动申请 Let's Encrypt 证书)
# 开发本机调试可设 localhost,Caddy 会签发自签名(浏览器需手动信任)
# 生产域名(已配置):jb.aijiaxia.cc → 154.9.238.144,Cloudflare 灰云直连
DOMAIN=jb.aijiaxia.cc

# 申请证书用的邮箱(Let's Encrypt 用,过期提醒)
ACME_EMAIL=yunkelai12251@gmail.com

# ===== 备份(可选)=====
# 如果用 restic 备份,在 host crontab 设置即可,不必走 .env
# RESTIC_REPOSITORY=/mnt/backup/restic-repo
# RESTIC_PASSWORD_FILE=/etc/restic/password
