# =========================================
# 前端环境变量示例
# =========================================
# 用法: cp .env.example .env.local
# .env.local 不入 git
# =========================================

# 后端 API 基地址
# - 本地开发:留空或 / ,走 vite proxy(配置见 vite.config.ts)
# - 直连开发:VITE_API_BASE=http://localhost:8000
# - 生产:留空(由 Caddy 反代,与前端同源)
VITE_API_BASE=
